# ===========================================
# Pawdise — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ===========================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=

# --- Replicate (Pixel Art Generation) ---
REPLICATE_API_TOKEN=

# --- Google OAuth (configured in Supabase dashboard, not here) ---
# Google Client ID and Secret are set in Supabase Auth settings directly.
# No env vars needed in the app for OAuth.
